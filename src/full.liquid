<div class="layout layout--row layout--top gap gap--large portrait:hidden">
  <div class="w--[50cqw] h--full">
    {% render 'table' plugins_sorted: plugins_sorted %}
  </div>

  <div class="w--[50cqw] h--full">
    <div class="layout layout--col h--full">
      {% if data.growth | size > 0 %}
      <div class="w--full">
        <div class="text--center">
          <span class="description description--small">7 Day Connection Growth Trend</span>
        </div>
        <div class="h--[28cqh]" id="{{ growth_chart_landscape_id }}"></div>
      </div>
      {% endif %}

      <div class="w--full stretch-y">
        <div class="flex flex--row flex--between mb--2">
          <div class="px--5 text--center">
            <div class="text--center">
              <span class="value value--small lg:value--base">{{ data.stats.plugins | round: 0 }}</span>
              <br />
              <span class="label label--small lg:label--base">Plugin{% if data.stats.plugins != 1 %}s{% endif %}</span>
            </div>
          </div>
          <div class="px--5">
            <div class="text--center">
              <span class="value value--small lg:value--base">{{ data.stats.connections | round: 0 }}</span>
              <br />
              <span class="label label--small lg:label--base">Connection{% if data.stats.connections != 1 %}s{% endif %}</span>
            </div>
          </div>
          <div class="px--5">
            <div class="text--center">
              <span class="value value--small lg:value--base">{{ data.stats.pageviews | round: 0 }}</span>
              <br />
              <span class="label label--small lg:label--base">Pageview{% if data.stats.pageviews != 1 %}s{% endif %}</span>
            </div>
          </div>
        </div>

        <div class="divider h--4"></div>

        <div class="text--center h--7">
          <span class="description description--small">Plugin Health (All Connections)</span>
        </div>

        <div class="grid grid--cols-1 px--5 w--full">
          <div class="row">
            <div class="grow">
              <div class="bg--error h--8" style="width: {{ data.health.erroring.percent }}%; overflow: hidden;">&nbsp;</div>
            </div>
            <div class="text--right">
              <span class="label label--small lg:label--base">Erroring</span>
              <span>&nbsp;</span>
              <span class="value value--xsmall lg:value--base">{{ data.health.erroring.percent | round: 0 }}%</span>
            </div>
          </div>
          <div class="row">
            <div class="grow">
              <div class="bg--warning h--8" style="width: {{ data.health.degraded.percent }}%; overflow: hidden;">&nbsp;</div>
            </div>
            <div class="text--right">
              <span class="label label--small lg:label--base">Degraded</span>
              <span>&nbsp;</span>
              <span class="value value--xsmall lg:value--base">{{ data.health.degraded.percent | round: 0 }}%</span>
            </div>
          </div>
          <div class="row">
            <div class="grow">
              <div class="bg--success h--8" style="width: {{ data.health.healthy.percent }}%; overflow: hidden;">&nbsp;</div>
            </div>
            <div class="text--right">
              <span class="label label--small lg:label--base">Healthy</span>
              <span>&nbsp;</span>
              <span class="value value--xsmall lg:value--base">{{ data.health.healthy.percent | round: 0 }}%</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="hidden portrait:block w--full">
  <div class="layout layout--col layout--stretch-x gap w--full">
  <div class="h--[50cqh] overflow-hidden w--full">
    {% render 'table' plugins_sorted: plugins_sorted %}
  </div>

  {% if data.growth | size > 0 %}
  <div class="h--[25cqh] w--full">
    <div class="text--center mb--1">
      <span class="description description--small">7 Day Connection Growth Trend</span>
    </div>
    <div class="h--full" id="{{ growth_chart_portrait_id }}"></div>
  </div>
  {% endif %}

  <div class="h--[25cqh] w--full">
    <div class="text--center h--7">
      <span class="description description--small">Plugin Health (All Connections)</span>
    </div>

    <div class="grid grid--cols-1 px--5 w--full">
      <div class="row">
        <div class="grow">
          <div class="bg--error h--8" style="width: {{ data.health.erroring.percent }}%; overflow: hidden;">&nbsp;</div>
        </div>
        <div class="text--right">
          <span class="label label--small lg:label--base">Erroring</span>
          <span>&nbsp;</span>
          <span class="value value--xsmall lg:value--base">{{ data.health.erroring.percent | round: 0 }}%</span>
        </div>
      </div>
      <div class="row">
        <div class="grow">
          <div class="bg--warning h--8" style="width: {{ data.health.degraded.percent }}%; overflow: hidden;">&nbsp;</div>
        </div>
        <div class="text--right">
          <span class="label label--small lg:label--base">Degraded</span>
          <span>&nbsp;</span>
          <span class="value value--xsmall lg:value--base">{{ data.health.degraded.percent | round: 0 }}%</span>
        </div>
      </div>
      <div class="row">
        <div class="grow">
          <div class="bg--success h--8" style="width: {{ data.health.healthy.percent }}%; overflow: hidden;">&nbsp;</div>
        </div>
        <div class="text--right">
          <span class="label label--small lg:label--base">Healthy</span>
          <span>&nbsp;</span>
          <span class="value value--xsmall lg:value--base">{{ data.health.healthy.percent | round: 0 }}%</span>
        </div>
      </div>
    </div>
  </div>
  </div>
</div>

<div class="title_bar">
  <img class="image image-stroke--medium" src="data:image/svg+xml;base64,{{ logo_svg | base64_encode }}" />
  <span class="title">Updated {{ 'now' | date: '%B %-d, %Y' }}</span>
  <span class="instance">{{ trmnl.plugin_settings.instance_name }}</span>
</div>

<script>
{% if data.growth | size > 0 %}
const growthData = {{ data.growth | json }};
const formattedData = growthData.map(([date, value]) => [
  new Date(date).getTime(),
  value
]);

const chartTargetIds = [
  "{{ growth_chart_portrait_id }}",
  "{{ growth_chart_landscape_id }}"
];

chartTargetIds.forEach((chartTargetId) => {
  Highcharts.chart(chartTargetId, {
    title: false,
    chart: {
      type: "column",
      animation: false,
    },

    series: [{
      data: formattedData,
      color: {
        pattern: {
          image: "https://trmnl.com/images/grayscale/gray-10.png",
          width: 12,
          height: 12
        }
      }
    }],

    plotOptions: {
      series: {
        animation: false,
        enableMouseTracking: false,
        states: {
          hover: { enabled: false }
        },
        pointPadding: 0.05,  // Reduced padding for more bars
        groupPadding: 0.1,
        borderWidth: 0
      }
    },

    yAxis: {
      allowDecimals: false,     // ✅ only whole numbers
      tickInterval: 1,          // ✅ enforce integer steps
      min: 0,                   // optional but helpful
      labels: {
        style: { fontSize: "16px", color: "#000000" }
      },
      gridLineDashStyle: "shortdot",
      gridLineWidth: 1,
      gridLineColor: "#000000",
      title: { text: null }
    },

    xAxis: {
      type: "datetime",         // ✅ switch to datetime
      tickInterval: 24 * 3600 * 1000, // one day
      labels: {
        format: "{value:%a}",   // ✅ Mon, Tue, Wed...
        rotation: 0,            // ✅ force horizontal
        style: { fontSize: "16px", color: "#000000" },
        y: 25
      },
      gridLineWidth: 1,
      gridLineColor: "#000000",
      title: { text: null }
    },
    tooltip: { enabled: false },
    legend: { enabled: false },
    credits: { enabled: false }
  });
});
{% endif %}

</script>
